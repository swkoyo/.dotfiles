#!/usr/bin/env bash

PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

##### Bar Appearance #####
sketchybar --bar position=top height=40 blur_radius=30 color=0x40000000

##### Defaults #####
default=(
  padding_left=5
  padding_right=5
  icon.font="Hack Nerd Font:Bold:17.0"
  label.font="Hack Nerd Font:Bold:14.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

##### Workspace Indicators #####
sketchybar --add event aerospace_workspace_change

# Function to refresh workspace items
refresh_workspaces() {
  # Get workspaces with windows
  ACTIVE_WORKSPACES=$(aerospace list-windows --all --format '%{workspace}' | sort -u)
  
  # Get existing space items in SketchyBar
  EXISTING_ITEMS=$(sketchybar --query bar | jq -r '.items[] | select(startswith("space."))')

  # Remove all existing space items
  for item in $EXISTING_ITEMS; do
    sketchybar --remove "$item"
  done

  # Add items for active workspaces
  for sid in $ACTIVE_WORKSPACES; do
    sketchybar --add item space.$sid left \
               --set space.$sid \
                    label="$sid" \
                    label.padding_left=8 \
                    label.padding_right=8 \
                    background.color=0x44ffffff \
                    background.corner_radius=5 \
                    background.height=24 \
                    background.drawing=off \
                    click_script="aerospace workspace $sid" \
                    script="$PLUGIN_DIR/aerospace.lua $sid" \
               --subscribe space.$sid aerospace_workspace_change
  done

  # Trigger update to highlight the focused workspace
  sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$FOCUSED_WORKSPACE"
}

# Initial workspace setup
refresh_workspaces

##### Left Items #####
sketchybar --add item chevron left \
           --set chevron icon= label.drawing=off \
           --add item front_app left \
           --set front_app icon.drawing=off script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

##### Right Items #####
sketchybar --add item clock right \
           --set clock update_freq=10 icon= script="$PLUGIN_DIR/clock.sh" \
           --add item volume right \
           --set volume script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change \
           --add item battery right \
           --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

##### Force Scripts to Run #####
sketchybar --update
